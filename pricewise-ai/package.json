{
  "name": "pricewise-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "npm run dev --prefix client",
    "server": "node server/scripts/startServer.js",
    "verify:smoke": "node server/scripts/smokeCheck.js",
    "install:all": "npm install && npm install --prefix client && npm install --prefix server"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}